# =========================================================================
# Pokémon Explorers - Environment Variables
# Copy this file to `.env` (for dev) or set these in your host's dashboard.
# =========================================================================

# --- Server port (optional, defaults to 3000) ------------------------------
# Most cloud hosts (Render, Fly, Railway, Heroku) inject their own PORT.
PORT=3000

# --- Gemini (optional) -----------------------------------------------------
# Only needed if you want AI-generated battle backgrounds.
# Without it, the app falls back to the static / PixelLab battle backgrounds.
# Get a free key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Firebase (required for multiplayer) -----------------------------------
# By default the app reads `firebase-applet-config.json` (shared AI Studio
# project). If you want your OWN Firebase project (recommended for hosting
# with friends long-term), fill these in. When these are set, they override
# the JSON file.
#
# Create a project: https://console.firebase.google.com
#   1. Enable Authentication -> Google sign-in
#   2. Create a Firestore database (in "production mode")
#   3. Deploy `firestore.rules` (firebase deploy --only firestore:rules)
#   4. Project Settings -> Your apps -> Web app -> copy config values below
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
# Optional: only needed if you use a NAMED (non-"(default)") Firestore database
VITE_FIREBASE_FIRESTORE_DB_ID=
